{
  "name": "veilwright-mcp",
  "version": "0.7.2",
  "description": "Multi-tenant MCP server bridging Claude Code to Veilwright AI WordPress sites.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/mcp/server.ts",
    "dev:http": "tsx watch src/http/server.ts",
    "build": "tsc -p tsconfig.json",
    "build:release": "tsc -p tsconfig.release.json",
    "start": "node dist/mcp/server.js",
    "start:http": "node dist/http/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "express": "^4.19.2",
    "jose": "^5.9.0",
    "oidc-provider": "^8.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/oidc-provider": "^8.8.1",
    "eslint": "^9.9.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
